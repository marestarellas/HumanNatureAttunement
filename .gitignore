# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environments
.venv/
venv/
env/
.conda/
*.egg-info/
.eggs/
dist/
build/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VSCode / IDE
.vscode/
.idea/

# Logs and dumps
*.log
*.out
*.err

# OS-specific
.DS_Store
Thumbs.db

# Data (keep raw/large files local unless using Git LFS)
data/
image_database/

# Generated figures: track ONLY the curated set used by the report.
# Everything else (per-subject plots, intermediate violins/topomaps) is
# regenerable from the scripts in scripts/figures/.
figures/*
!figures/report/
# Skip vector duplicates of the report figures (PNGs are tracked).
figures/report/*.pdf

# Compiled LaTeX artefacts (regenerable from .tex via tectonic).
reports/**/*.pdf
reports/**/*.aux
reports/**/*.log
reports/**/*.out
reports/**/*.toc
reports/**/*.bbl
reports/**/*.blg
reports/**/*.synctex.gz

# Ignore test cache
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.bak
*.swp

data/*
!data/README.md
