# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environments
.venv/
venv/
env/
.conda/
*.egg-info/
.eggs/
dist/
build/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VSCode / IDE
.vscode/
.idea/

# Logs and dumps
*.log
*.out
*.err

# OS-specific
.DS_Store
Thumbs.db

# Data (keep raw/large files local unless using Git LFS)
data/
image_database/

# Generated analysis figures: regenerable from scripts in scripts/figures/.
# Ignored entirely; the curated report-ready set lives next to its TeX
# under reports/<report_name>/figures/ and is tracked there. The PDF
# vector duplicates of those report-ready PNGs are caught by the
# reports/**/*.pdf rule below.
figures/*

# Compiled LaTeX artefacts (regenerable from .tex via tectonic).
reports/**/*.pdf
reports/**/*.aux
reports/**/*.log
reports/**/*.out
reports/**/*.toc
reports/**/*.bbl
reports/**/*.blg
reports/**/*.synctex.gz

# Ignore test cache
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.bak
*.swp

data/*
!data/README.md
